# Copy to .env and fill in. NEVER commit real values (.env is gitignored).
# This file documents the SHAPE of required secrets only.

# --- LaunchDarkly: FACTORY / control-plane project ---
# Holds the agent AI configs, the agent graph, and operational flags
# (auto-factory-ai-provider, approval/yolo mode). The prototype READS from here.
#
# Server SDK key (sdk-...) for the factory project's environment. Used by the
# Node server SDK (flag evaluation) + AI SDK (agent configs + agent graphs).
LD_SDK_KEY=
# API key (api-...) for REST operations (e.g. creating flags in the app project).
LD_API_KEY=
# REST API base URL.
LD_BASE_URL=https://app.launchdarkly.com
# Factory/control-plane project key (where AI configs + graph + control flags live).
LD_PROJECT_KEY=
# Internal LaunchDarkly project ID (NOT the project key). Sent as Vega dispatch
# `project_slug`. Find it via the Vega/observability API; falls back to LD_PROJECT_KEY.
LD_PROJECT_SLUG=

# --- Anthropic (DEFAULT agent execution backend) ---
# Required when the `auto-factory-ai-provider` flag serves 'anthropic' — the
# DEFAULT. The local Anthropic runner uses each AI config's instructions as the
# agent system prompt. Only optional if the provider flag is set to 'vega'.
ANTHROPIC_API_KEY=

# --- LaunchDarkly: APP / data-plane project ---
# Where agents auto-CREATE feature flags and where Phase 2 auto-releases them.
# Kept separate from the factory project for blast-radius isolation.
LD_APP_PROJECT_KEY=autofactory-demo

# --- LaunchDarkly source (optional): where to pull initial configs + graphs from ---
# Design partners may seed from the shared "auto-factory-prototype" project.
# Leave blank to provision straight from the canonical local copies in the repo.
LD_SOURCE_API_KEY=
LD_SOURCE_BASE_URL=
LD_SOURCE_PROJECT_KEY=

# --- Vega (Phase 1 agent dispatch — only when the provider flag serves 'vega') ---
# NOTE: the Agent Dispatch API must be enabled for the project via a LaunchDarkly
# flag / entitlement before Vega dispatch works at all.
# GraphQL endpoint for dispatching agents (deployment-specific). If unset, the
# action uses a no-op stub transport.
VEGA_ENDPOINT=
# Auth is a regular LaunchDarkly API key sent raw in the Authorization header.
# Leave VEGA_TOKEN blank to reuse LD_API_KEY.
VEGA_TOKEN=
# Optional: override the auth header name if the endpoint expects a non-standard one.
VEGA_AUTH_HEADER=

# --- Phase 1 behavior toggles (read from env / action inputs) ---
# Master switches for what the agents are allowed to do. All optional; the
# defaults below are read-only/dry-run-safe.
#
# 'true' lets the flag-implementer create REAL flags in the app project (needs
# LD_API_KEY + LD_APP_PROJECT_KEY). 'false' = read-only dry run.
ENABLE_FLAG_CREATION=false
# 'true' lets agents edit files and commit+push to the PR branch (needs a token
# with contents:write). 'false' = no writes to the repo.
ENABLE_CODE_CHANGES=false
# Approval gate: yolo (auto-apply on approval) | middle (gate high risk on a
# human) | manual (always require a human). Default yolo.
APPROVAL_MODE=yolo
# Agent graph key to resolve from LaunchDarkly and walk. Default gha-auto-factory.
GRAPH_KEY=gha-auto-factory
# Repo path the agent tools inspect/edit. Defaults to examples/demo-app locally,
# "." (the checked-out workspace) in CI.
SANDBOX_ROOT=
# Vega dispatch request type / persona (e.g. Fix). Only used on the Vega path.
VEGA_REQUEST_TYPE=
# Key for the "service"-kind LaunchDarkly context used for flag eval + AI config
# / graph targeting. Default auto-factory-phase1.
LD_PIPELINE_CONTEXT_KEY=auto-factory-phase1

# --- GitHub (Phase 1 GitHub Action) ---
GITHUB_TOKEN=

# --- Railway (Phase 2 CD) ---
RAILWAY_TOKEN=

# --- Beacon (Phase 2 orchestrator) ---
# Shared secret the Notifier uses to authenticate POSTs to Beacon.
BEACON_WEBHOOK_SECRET=
