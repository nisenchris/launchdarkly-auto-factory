 # --- Proprietary source material — NEVER commit ---
# This repo is PUBLIC. reference-private/ holds the internal build and other
# proprietary material we draw inspiration from. It must never be tracked.
reference-private/

# Vendored external repos (synced on demand; pinned in sources/manifest.yaml)
sources/repos/

# Staging dir for `bridge seed` — runtime-pulled AI configs/graph from the
# source LD project, provisioned straight into the target. Never committed
# (these bypass check-public; the source LD project is the sanitization boundary).
.agentcontrol-cache/

# --- Secrets ---
.env
.env.local
*.local

# --- Dependencies / build output ---
node_modules/
dist/
build/
*.tsbuildinfo
.venv/
__pycache__/
*.pyc
.pytest_cache/

# Exception: the Phase 1 action's esbuild bundle MUST be committed so
# `uses: <owner>/launchdarkly-auto-factory/packages/phase1-resource-factory@ref`
# resolves (GitHub runs the prebuilt `main:` bundle). Only the bundle, not the
# rest of dist/. Rebuild with `npm run bundle -w @auto-factory/phase1-resource-factory`.
!packages/phase1-resource-factory/dist/
packages/phase1-resource-factory/dist/*
!packages/phase1-resource-factory/dist/action.bundle.js

# --- Editor / OS ---
.DS_Store
*.swp
.vscode/

# examples/demo-app is the default agent SANDBOX_ROOT — with ENABLE_CODE_CHANGES,
# agents may write/modify a README here during local runs. Ignored so that churn
# isn't accidentally committed. (GUIDE.md is the tracked, human-authored guide.)
examples/demo-app/README.md

docs/build-checklist.md
docs/demo-punchlist.md
docs/ISSUES.md
docs/demo-pipeline-runbook.md
docs/phase2-unknowns.md

# Beacon's local deploy-state store (BEACON_STATE_FILE default)
beacon-state.json

# Phase 1 Cursor extension working notes (local-only)
docs/phase1-cursor-unknowns.md

# Packaged extension artifacts
*.vsix
PLAN-structured-intent.md
